{
  "name": "@shaykec/agent-web",
  "version": "0.3.2",
  "description": "Generic framework for exposing Claude Code to web apps — server middleware, React hooks, and embeddable components",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./protocol": "./src/protocol/index.js",
    "./server": "./src/server/index.js",
    "./react": "./src/client/index.js",
    "./components": "./src/client/components/index.js",
    "./client": "./src/vanilla/index.js"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "npm test",
    "test": "vitest run",
    "test:unit": "vitest run tests/protocol tests/server tests/client tests/vanilla",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:e2e:browser": "node scripts/run-browser-tests.js",
    "test:e2e:macos": "vitest run tests/e2e/macos-app.test.js",
    "test:swift": "cd examples/macos-app/AgentChat && swift test",
    "test:all": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "example:quickstart": "node examples/minimal-chat/server.js",
    "example:minimal": "node examples/minimal-chat/server.js",
    "example:embeddable": "node examples/react-embeddable/server.js",
    "example:hooks": "node examples/react-custom-hooks/server.js",
    "example:vanilla": "node examples/vanilla-js/server.js",
    "example:express": "node examples/express-middleware/server.js",
    "example:multi": "node examples/multi-session/server.js",
    "example:macos": "node examples/macos-app/server.js",
    "lint": "echo 'No linter configured yet'"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agent-sdk",
    "ai",
    "chat",
    "websocket",
    "react",
    "hooks",
    "embeddable"
  ],
  "author": "shaykec",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shayke-cohen/local-agent-web.git"
  },
  "homepage": "https://github.com/shayke-cohen/local-agent-web#readme",
  "bugs": {
    "url": "https://github.com/shayke-cohen/local-agent-web/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "ws": "^8.16.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vitest": "^3.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "jsdom": "^25.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
